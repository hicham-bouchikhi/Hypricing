<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Hypricing.Desktop.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />

        <!-- ═══════════════ Window ═══════════════ -->
        <Style Selector="Window">
            <Setter Property="Background" Value="#1e1e2e" />
            <Setter Property="Foreground" Value="#cdd6f4" />
            <Setter Property="FontFamily" Value="Inter, Segoe UI, sans-serif" />
        </Style>

        <!-- ═══════════════ Cards ═══════════════ -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#313244" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="BorderBrush" Value="#3b3b52" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BoxShadow" Value="0 2 12 0 #22000000" />
        </Style>
        <Style Selector="Border.card-elevated">
            <Setter Property="Background" Value="#313244" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="BorderBrush" Value="#3b3b52" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BoxShadow" Value="0 4 20 0 #32000000" />
        </Style>
        <Style Selector="Border.card-item">
            <Setter Property="Background" Value="#24243a" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="BorderBrush" Value="#35354e" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.12" />
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.12" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.card-item:pointerover">
            <Setter Property="Background" Value="#2e2e48" />
            <Setter Property="BorderBrush" Value="#585b70" />
        </Style>

        <!-- ═══════════════ TextBox ═══════════════ -->
        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="#3b3b54" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#45475a" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Foreground" Value="#cdd6f4" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                    <BrushTransition Property="Background" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#45475a" />
            <Setter Property="BorderBrush" Value="#585b70" />
        </Style>
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#89b4fa" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#3b3b54" />
        </Style>

        <!-- ═══════════════ Accent Button ═══════════════ -->
        <Style Selector="Button.accent">
            <Setter Property="Background" Value="#89b4fa" />
            <Setter Property="Foreground" Value="#1e1e2e" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.accent:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#b4d0fb" />
        </Style>
        <Style Selector="Button.accent:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#7ba3e8" />
        </Style>

        <!-- ═══════════════ Danger Button ═══════════════ -->
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#f38ba8" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#5e3045" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="Button.danger:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#3e2030" />
            <Setter Property="BorderBrush" Value="#f38ba8" />
        </Style>

        <!-- ═══════════════ Ghost Button ═══════════════ -->
        <Style Selector="Button.ghost">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#a6adc8" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.ghost:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#313244" />
            <Setter Property="Foreground" Value="#cdd6f4" />
        </Style>

        <!-- ═══════════════ Nav Item Button (sidebar footer) ═══════════════ -->
        <Style Selector="Button.nav-item">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#6c7086" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Foreground" Duration="0:0:0.12" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.nav-item:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#1c1c2e" />
        </Style>
        <Style Selector="Button.nav-item:pointerover">
            <Setter Property="Foreground" Value="#a6adc8" />
        </Style>

        <!-- ═══════════════ Default Button ═══════════════ -->
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14,8" />
        </Style>

        <!-- ═══════════════ ComboBox ═══════════════ -->
        <Style Selector="ComboBox">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="#3b3b54" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#45475a" />
        </Style>

        <!-- ═══════════════ Sidebar ═══════════════ -->
        <Style Selector="ListBox.sidebar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="ListBox.sidebar ListBoxItem">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="Foreground" Value="#6c7086" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Foreground" Duration="0:0:0.12" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="ListBox.sidebar ListBoxItem:pointerover">
            <Setter Property="Foreground" Value="#a6adc8" />
        </Style>
        <Style Selector="ListBox.sidebar ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#1c1c2e" />
        </Style>
        <Style Selector="ListBox.sidebar ListBoxItem:selected">
            <Setter Property="Foreground" Value="#89b4fa" />
        </Style>
        <Style Selector="ListBox.sidebar ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#1e2a45" />
        </Style>
        <Style Selector="ListBox.sidebar ListBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#22305a" />
        </Style>

        <!-- ═══════════════ Badge ═══════════════ -->
        <Style Selector="Border.badge">
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Background" Value="#2a3a55" />
        </Style>

        <!-- ═══════════════ Typography ═══════════════ -->
        <Style Selector="TextBlock.page-title">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#cdd6f4" />
            <Setter Property="Margin" Value="0,0,0,20" />
        </Style>

        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#9399b2" />
            <Setter Property="Margin" Value="4,16,0,8" />
        </Style>

        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="#585b70" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style Selector="TextBlock.status">
            <Setter Property="Foreground" Value="#a6adc8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="TextBlock.mono">
            <Setter Property="FontFamily" Value="JetBrains Mono, Cascadia Code, monospace" />
        </Style>

        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="#7f849c" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- ═══════════════ Separator ═══════════════ -->
        <Style Selector="Border.separator">
            <Setter Property="Height" Value="1" />
            <Setter Property="Background" Value="#313244" />
            <Setter Property="Margin" Value="0,8" />
        </Style>

        <!-- ═══════════════ ScrollViewer ═══════════════ -->
        <Style Selector="ScrollViewer">
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>

        <!-- ═══════════════ Content transitions ═══════════════ -->
        <Style Selector="ContentControl.page-host">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>

    </Application.Styles>
</Application>

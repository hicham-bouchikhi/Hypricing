<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Hypricing.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="Hypricing.Desktop.Views.NetworkView"
             x:DataType="vm:NetworkViewModel">

    <DockPanel>

        <TextBlock DockPanel.Dock="Top"
                   Classes="page-title"
                   Text="Network" />

        <!-- Bottom bar -->
        <Border DockPanel.Dock="Bottom"
                Classes="card-elevated"
                CornerRadius="12,12,0,0"
                Padding="20,14"
                Margin="0,16,0,0">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <TextBlock Grid.Column="0"
                           Classes="status"
                           Text="{Binding StatusMessage}" />
                <Button Grid.Column="1"
                        Classes="ghost"
                        Content="{Binding ScanLabel}"
                        Command="{Binding ScanCommand}"
                        IsEnabled="{Binding !IsScanning}"
                        Margin="0,0,8,0" />
                <Button Grid.Column="2"
                        Classes="ghost"
                        Content="{Binding WifiToggleLabel}"
                        Command="{Binding ToggleWifiCommand}"
                        IsEnabled="{Binding !IsScanning}"
                        Margin="0,0,8,0" />
                <Button Grid.Column="3"
                        Classes="accent"
                        Content="Refresh"
                        Command="{Binding RefreshCommand}"
                        IsEnabled="{Binding !IsScanning}" />
            </Grid>
        </Border>

        <ScrollViewer>
            <StackPanel Spacing="24">

                <!-- Interfaces -->
                <StackPanel>
                    <TextBlock Classes="section-title" Text="Interfaces" />
                    <Border Classes="card">
                        <ItemsControl ItemsSource="{Binding Devices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:NetworkDeviceViewModel">
                                    <Border Classes="card-item" Padding="14,12">
                                        <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="#cdd6f4"
                                                               FontFamily="JetBrains Mono, Cascadia Code, monospace" />
                                                    <TextBlock Text="{Binding Connection}"
                                                               IsVisible="{Binding Connection, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                               Classes="muted"
                                                               FontSize="13"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding IpAddress}"
                                                           IsVisible="{Binding IpAddress, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                           Classes="muted"
                                                           FontFamily="JetBrains Mono, Cascadia Code, monospace"
                                                           FontSize="12" />
                                            </StackPanel>
                                            <Border Grid.Column="1"
                                                    Classes="badge"
                                                    Margin="0,0,8,0">
                                                <TextBlock Text="{Binding TypeLabel}"
                                                           FontSize="11"
                                                           Foreground="#89b4fa"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center" />
                                            </Border>
                                            <Border Grid.Column="2"
                                                    Classes="badge"
                                                    IsVisible="{Binding IsConnected}"
                                                    Margin="0,0,8,0">
                                                <TextBlock Text="Connected"
                                                           FontSize="11"
                                                           Foreground="#a6e3a1"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center" />
                                            </Border>
                                            <Border Grid.Column="3"
                                                    Classes="badge"
                                                    IsVisible="{Binding !IsConnected}"
                                                    Margin="0,0,8,0">
                                                <TextBlock Text="{Binding State}"
                                                           FontSize="11"
                                                           Foreground="#6c7086"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center" />
                                            </Border>
                                            <Button Grid.Column="4"
                                                    Classes="ghost"
                                                    Content="Disconnect"
                                                    Command="{Binding DisconnectCommand}"
                                                    IsVisible="{Binding CanDisconnect}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>

                <!-- WiFi Networks -->
                <StackPanel IsVisible="{Binding WifiEnabled}">
                    <TextBlock Classes="section-title" Text="WiFi Networks" />
                    <Border Classes="card">
                        <ItemsControl ItemsSource="{Binding Networks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:WifiNetworkViewModel">
                                    <Border Classes="card-item" Padding="14,12">
                                        <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Ssid}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="#cdd6f4"
                                                       VerticalAlignment="Center" />

                                            <!-- Signal bars -->
                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        Spacing="2"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,10,0">
                                                <Border Width="4" Height="8"  CornerRadius="1" Background="#89b4fa" Opacity="{Binding Bar1Opacity}" VerticalAlignment="Bottom" />
                                                <Border Width="4" Height="12" CornerRadius="1" Background="#89b4fa" Opacity="{Binding Bar2Opacity}" VerticalAlignment="Bottom" />
                                                <Border Width="4" Height="16" CornerRadius="1" Background="#89b4fa" Opacity="{Binding Bar3Opacity}" VerticalAlignment="Bottom" />
                                                <Border Width="4" Height="20" CornerRadius="1" Background="#89b4fa" Opacity="{Binding Bar4Opacity}" VerticalAlignment="Bottom" />
                                            </StackPanel>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Security}"
                                                       Classes="muted"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0" />
                                            <Border Grid.Column="3"
                                                    Classes="badge"
                                                    IsVisible="{Binding Active}"
                                                    Margin="0,0,8,0">
                                                <TextBlock Text="Connected"
                                                           FontSize="11"
                                                           Foreground="#a6e3a1"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center" />
                                            </Border>
                                            <Button Grid.Column="4"
                                                    Classes="ghost"
                                                    Content="Connect"
                                                    Command="{Binding ConnectCommand}"
                                                    IsVisible="{Binding !Active}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>

</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Hypricing.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="Hypricing.Desktop.Views.KeybindingsView"
             x:DataType="vm:KeybindingsViewModel">

    <DockPanel>

        <TextBlock DockPanel.Dock="Top"
                   Classes="page-title"
                   Text="Keybindings" />

        <!-- Bottom bar -->
        <Border DockPanel.Dock="Bottom"
                Classes="card-elevated"
                CornerRadius="12,12,0,0"
                Padding="20,14"
                Margin="0,16,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Classes="status"
                           Text="{Binding StatusMessage}" />
                <Button Grid.Column="1"
                        Classes="accent"
                        Content="Save"
                        Command="{Binding SaveCommand}" />
            </Grid>
        </Border>

        <ScrollViewer>
            <StackPanel Spacing="16">

                <!-- Add new keybinding -->
                <Border Classes="card-elevated">
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="100,110,90,*,Auto">
                            <ComboBox Grid.Column="0"
                                      ItemsSource="{x:Static vm:BindItemViewModel.AllVariants}"
                                      SelectedItem="{Binding NewVariant}"
                                      Margin="0,0,8,0" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding NewModifiers, Mode=TwoWay}"
                                     Watermark="SUPER, ALT..."
                                     Margin="0,0,8,0" />
                            <TextBox Grid.Column="2"
                                     Text="{Binding NewKey, Mode=TwoWay}"
                                     Watermark="Key"
                                     Margin="0,0,8,0" />
                            <TextBox Grid.Column="3"
                                     Text="{Binding NewDispatcher, Mode=TwoWay}"
                                     Watermark="Dispatcher"
                                     Margin="0,0,8,0" />
                            <Button Grid.Column="4"
                                    Classes="accent"
                                    Content="Add"
                                    Command="{Binding AddCommand}" />
                        </Grid>
                        <TextBox Text="{Binding NewArgs, Mode=TwoWay}"
                                 Watermark="Arguments (optional)"
                                 IsVisible="{Binding NewDispatcher, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>
                </Border>

                <!-- Keybindings list -->
                <Border Classes="card">
                    <ItemsControl ItemsSource="{Binding Keybindings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:BindItemViewModel">
                                <Border Classes="card-item">
                                    <StackPanel Spacing="6">
                                        <Grid ColumnDefinitions="Auto,110,80,*,Auto">
                                            <Border Grid.Column="0"
                                                    Classes="badge"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,10,0">
                                                <TextBlock Text="{Binding Variant}"
                                                           FontFamily="JetBrains Mono, Cascadia Code, monospace"
                                                           FontSize="11"
                                                           Foreground="#f9e2af" />
                                            </Border>
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding Modifiers, Mode=TwoWay}"
                                                     Watermark="Mods"
                                                     Margin="0,0,6,0" />
                                            <TextBox Grid.Column="2"
                                                     Text="{Binding Key, Mode=TwoWay}"
                                                     Watermark="Key"
                                                     Margin="0,0,6,0" />
                                            <TextBox Grid.Column="3"
                                                     Text="{Binding Dispatcher, Mode=TwoWay}"
                                                     Watermark="Dispatcher"
                                                     Margin="0,0,10,0" />
                                            <Button Grid.Column="4"
                                                    Classes="danger"
                                                    Content="Remove"
                                                    Command="{Binding RemoveCommand}" />
                                        </Grid>
                                        <TextBox Text="{Binding Args, Mode=TwoWay}"
                                                 Watermark="Arguments"
                                                 IsVisible="{Binding Dispatcher, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>

</UserControl>

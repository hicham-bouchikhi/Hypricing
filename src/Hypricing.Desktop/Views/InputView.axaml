<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Hypricing.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="900"
             x:Class="Hypricing.Desktop.Views.InputView"
             x:DataType="vm:InputViewModel">

    <DockPanel>

        <TextBlock DockPanel.Dock="Top"
                   Classes="page-title"
                   Text="Input" />

        <!-- Bottom bar -->
        <Border DockPanel.Dock="Bottom"
                Classes="card-elevated"
                CornerRadius="12,12,0,0"
                Padding="20,14"
                Margin="0,16,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Classes="status"
                           Text="{Binding StatusMessage}" />
                <Button Grid.Column="1"
                        Classes="accent"
                        Content="Save"
                        Command="{Binding SaveCommand}" />
            </Grid>
        </Border>

        <ScrollViewer>
            <StackPanel Spacing="24">

                <!-- ═══════════════ Keyboard ═══════════════ -->
                <StackPanel>
                    <TextBlock Classes="section-title" Text="Keyboard" />
                    <Border Classes="card">
                        <Grid ColumnDefinitions="140,*"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                              Margin="0,4,0,0">

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Layout"
                                       Foreground="#6c7086" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <ComboBox Grid.Row="0" Grid.Column="1"
                                      ItemsSource="{Binding Layouts}"
                                      SelectedItem="{Binding KbLayout, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch"
                                      FontFamily="JetBrains Mono, Cascadia Code, monospace"
                                      Margin="0,0,0,8" />

                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="Variant"
                                       Foreground="#6c7086" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <ComboBox Grid.Row="1" Grid.Column="1"
                                      ItemsSource="{Binding Variants}"
                                      SelectedItem="{Binding KbVariant, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch"
                                      FontFamily="JetBrains Mono, Cascadia Code, monospace"
                                      Margin="0,0,0,8" />

                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="Model"
                                       Foreground="#6c7086" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <TextBox Grid.Row="2" Grid.Column="1"
                                     Text="{Binding KbModel, Mode=TwoWay}"
                                     FontFamily="JetBrains Mono, Cascadia Code, monospace"
                                     Margin="0,0,0,8" />

                            <TextBlock Grid.Row="3" Grid.Column="0"
                                       Text="Options"
                                       Foreground="#6c7086" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <TextBox Grid.Row="3" Grid.Column="1"
                                     Text="{Binding KbOptions, Mode=TwoWay}"
                                     Watermark="ctrl:nocaps"
                                     FontFamily="JetBrains Mono, Cascadia Code, monospace"
                                     Margin="0,0,0,8" />

                            <TextBlock Grid.Row="4" Grid.Column="0"
                                       Text="Rules"
                                       Foreground="#6c7086" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <TextBox Grid.Row="4" Grid.Column="1"
                                     Text="{Binding KbRules, Mode=TwoWay}"
                                     FontFamily="JetBrains Mono, Cascadia Code, monospace"
                                     Margin="0,0,0,8" />

                            <TextBlock Grid.Row="5" Grid.Column="0"
                                       Text="Numlock"
                                       Foreground="#6c7086" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <ToggleSwitch Grid.Row="5" Grid.Column="1"
                                          IsChecked="{Binding NumlockByDefault, Mode=TwoWay}"
                                          OnContent="" OffContent=""
                                          Margin="0,0,0,8" />

                            <TextBlock Grid.Row="6" Grid.Column="0"
                                       Text="Repeat Rate"
                                       Foreground="#6c7086" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <Grid Grid.Row="6" Grid.Column="1"
                                  ColumnDefinitions="*,50" Margin="0,0,0,8">
                                <Slider Grid.Column="0"
                                        Minimum="1" Maximum="100"
                                        Value="{Binding RepeatRate, Mode=TwoWay}"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding RepeatRate}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Foreground="#a6adc8"
                                           FontFamily="JetBrains Mono, Cascadia Code, monospace"
                                           FontSize="13" />
                            </Grid>

                            <TextBlock Grid.Row="7" Grid.Column="0"
                                       Text="Repeat Delay"
                                       Foreground="#6c7086" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <Grid Grid.Row="7" Grid.Column="1"
                                  ColumnDefinitions="*,50" Margin="0,0,0,8">
                                <Slider Grid.Column="0"
                                        Minimum="100" Maximum="1000"
                                        Value="{Binding RepeatDelay, Mode=TwoWay}"
                                        TickFrequency="10"
                                        IsSnapToTickEnabled="True" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding RepeatDelay}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Foreground="#a6adc8"
                                           FontFamily="JetBrains Mono, Cascadia Code, monospace"
                                           FontSize="13" />
                            </Grid>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ═══════════════ Cursor &amp; Mouse ═══════════════ -->
                <StackPanel>
                    <TextBlock Classes="section-title" Text="Cursor &amp; Mouse" />
                    <Border Classes="card">
                        <Grid ColumnDefinitions="140,*"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                              Margin="0,4,0,0">

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Sensitivity"
                                       Foreground="#6c7086" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <Grid Grid.Row="0" Grid.Column="1"
                                  ColumnDefinitions="*,50" Margin="0,0,0,8">
                                <Slider Grid.Column="0"
                                        Minimum="-1" Maximum="1"
                                        Value="{Binding Sensitivity, Mode=TwoWay}"
                                        TickFrequency="0.1"
                                        IsSnapToTickEnabled="True" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Sensitivity, StringFormat='{}{0:F1}'}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Foreground="#a6adc8"
                                           FontFamily="JetBrains Mono, Cascadia Code, monospace"
                                           FontSize="13" />
                            </Grid>

                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="Accel Profile"
                                       Foreground="#6c7086" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <ComboBox Grid.Row="1" Grid.Column="1"
                                      ItemsSource="{x:Static vm:InputViewModel.AccelProfiles}"
                                      SelectedItem="{Binding AccelProfile, Mode=TwoWay}"
                                      MinWidth="160"
                                      Margin="0,0,0,8" />

                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="Follow Mouse"
                                       Foreground="#6c7086" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <ComboBox Grid.Row="2" Grid.Column="1"
                                      ItemsSource="{x:Static vm:InputViewModel.FollowMouseOptions}"
                                      SelectedItem="{Binding FollowMouseString, Mode=TwoWay}"
                                      MinWidth="160"
                                      Margin="0,0,0,8" />

                            <TextBlock Grid.Row="3" Grid.Column="0"
                                       Text="Left Handed"
                                       Foreground="#6c7086" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <ToggleSwitch Grid.Row="3" Grid.Column="1"
                                          IsChecked="{Binding LeftHanded, Mode=TwoWay}"
                                          OnContent="" OffContent=""
                                          Margin="0,0,0,8" />

                            <TextBlock Grid.Row="4" Grid.Column="0"
                                       Text="No HW Cursors"
                                       Foreground="#6c7086" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <ToggleSwitch Grid.Row="4" Grid.Column="1"
                                          IsChecked="{Binding NoHardwareCursors, Mode=TwoWay}"
                                          OnContent="" OffContent=""
                                          Margin="0,0,0,8" />

                            <TextBlock Grid.Row="5" Grid.Column="0"
                                       Text="Inactive Timeout"
                                       Foreground="#6c7086" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <Grid Grid.Row="5" Grid.Column="1"
                                  ColumnDefinitions="*,50" Margin="0,0,0,8">
                                <Slider Grid.Column="0"
                                        Minimum="0" Maximum="60"
                                        Value="{Binding InactiveTimeout, Mode=TwoWay}"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding InactiveTimeout, StringFormat='{}{0}s'}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Foreground="#a6adc8"
                                           FontFamily="JetBrains Mono, Cascadia Code, monospace"
                                           FontSize="13" />
                            </Grid>

                            <TextBlock Grid.Row="6" Grid.Column="0"
                                       Text="No Warps"
                                       Foreground="#6c7086" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <ToggleSwitch Grid.Row="6" Grid.Column="1"
                                          IsChecked="{Binding NoWarps, Mode=TwoWay}"
                                          OnContent="" OffContent=""
                                          Margin="0,0,0,8" />

                            <TextBlock Grid.Row="7" Grid.Column="0"
                                       Text="Persistent Warps"
                                       Foreground="#6c7086" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <ToggleSwitch Grid.Row="7" Grid.Column="1"
                                          IsChecked="{Binding PersistentWarps, Mode=TwoWay}"
                                          OnContent="" OffContent=""
                                          Margin="0,0,0,8" />

                            <TextBlock Grid.Row="8" Grid.Column="0"
                                       Text="Hyprcursor"
                                       Foreground="#6c7086" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <ToggleSwitch Grid.Row="8" Grid.Column="1"
                                          IsChecked="{Binding EnableHyprcursor, Mode=TwoWay}"
                                          OnContent="" OffContent=""
                                          Margin="0,0,0,8" />

                            <TextBlock Grid.Row="9" Grid.Column="0"
                                       Text="Hide on Key"
                                       Foreground="#6c7086" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <ToggleSwitch Grid.Row="9" Grid.Column="1"
                                          IsChecked="{Binding HideOnKeyPress, Mode=TwoWay}"
                                          OnContent="" OffContent=""
                                          Margin="0,0,0,8" />

                            <TextBlock Grid.Row="10" Grid.Column="0"
                                       Text="Hide on Touch"
                                       Foreground="#6c7086" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <ToggleSwitch Grid.Row="10" Grid.Column="1"
                                          IsChecked="{Binding HideOnTouch, Mode=TwoWay}"
                                          OnContent="" OffContent=""
                                          Margin="0,0,0,8" />
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ═══════════════ Touchpad ═══════════════ -->
                <StackPanel>
                    <TextBlock Classes="section-title" Text="Touchpad" />
                    <Border Classes="card">
                        <Grid ColumnDefinitions="140,*"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                              Margin="0,4,0,0">

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Natural Scroll"
                                       Foreground="#6c7086" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <ToggleSwitch Grid.Row="0" Grid.Column="1"
                                          IsChecked="{Binding NaturalScroll, Mode=TwoWay}"
                                          OnContent="" OffContent=""
                                          Margin="0,0,0,8" />

                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="Tap to Click"
                                       Foreground="#6c7086" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <ToggleSwitch Grid.Row="1" Grid.Column="1"
                                          IsChecked="{Binding TapToClick, Mode=TwoWay}"
                                          OnContent="" OffContent=""
                                          Margin="0,0,0,8" />

                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="Disable Typing"
                                       Foreground="#6c7086" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <ToggleSwitch Grid.Row="2" Grid.Column="1"
                                          IsChecked="{Binding DisableWhileTyping, Mode=TwoWay}"
                                          OnContent="" OffContent=""
                                          Margin="0,0,0,8" />

                            <TextBlock Grid.Row="3" Grid.Column="0"
                                       Text="Middle Btn Emu"
                                       Foreground="#6c7086" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <ToggleSwitch Grid.Row="3" Grid.Column="1"
                                          IsChecked="{Binding MiddleButtonEmulation, Mode=TwoWay}"
                                          OnContent="" OffContent=""
                                          Margin="0,0,0,8" />

                            <TextBlock Grid.Row="4" Grid.Column="0"
                                       Text="Scroll Factor"
                                       Foreground="#6c7086" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <Grid Grid.Row="4" Grid.Column="1"
                                  ColumnDefinitions="*,50" Margin="0,0,0,8">
                                <Slider Grid.Column="0"
                                        Minimum="0.1" Maximum="3"
                                        Value="{Binding ScrollFactor, Mode=TwoWay}"
                                        TickFrequency="0.1"
                                        IsSnapToTickEnabled="True" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ScrollFactor, StringFormat='{}{0:F1}'}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Foreground="#a6adc8"
                                           FontFamily="JetBrains Mono, Cascadia Code, monospace"
                                           FontSize="13" />
                            </Grid>

                            <TextBlock Grid.Row="5" Grid.Column="0"
                                       Text="Drag Lock"
                                       Foreground="#6c7086" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <ToggleSwitch Grid.Row="5" Grid.Column="1"
                                          IsChecked="{Binding DragLock, Mode=TwoWay}"
                                          OnContent="" OffContent=""
                                          Margin="0,0,0,8" />

                            <TextBlock Grid.Row="6" Grid.Column="0"
                                       Text="Clickfinger"
                                       Foreground="#6c7086" VerticalAlignment="Center" Margin="0,0,0,8" />
                            <ToggleSwitch Grid.Row="6" Grid.Column="1"
                                          IsChecked="{Binding ClickfingerBehavior, Mode=TwoWay}"
                                          OnContent="" OffContent=""
                                          Margin="0,0,0,8" />
                        </Grid>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>

</UserControl>

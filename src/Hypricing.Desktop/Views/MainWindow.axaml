<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Hypricing.Desktop.ViewModels"
        xmlns:views="using:Hypricing.Desktop.Views"
        mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="640"
        x:Class="Hypricing.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Hypricing"
        Width="1000" Height="680">

    <Grid ColumnDefinitions="240,*">

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="#11111b"
                Padding="0,16">
            <DockPanel>
                <!-- App branding -->
                <StackPanel DockPanel.Dock="Top" Margin="24,8,24,24">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Background="#89b4fa"
                                CornerRadius="8"
                                Width="32" Height="32"
                                Padding="0">
                            <TextBlock Text="H"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#11111b"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Hypricing"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#cdd6f4" />
                            <TextBlock Text="Settings Manager"
                                       FontSize="10"
                                       Foreground="#585b70" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Separator -->
                <Border DockPanel.Dock="Top" Classes="separator" Margin="16,0" />

                <!-- Backups at bottom -->
                <StackPanel DockPanel.Dock="Bottom" Margin="12,0">
                    <Border Classes="separator" Margin="4,0,4,4" />
                    <Button Classes="ghost"
                            Command="{Binding OpenBackupsCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="12,10"
                            CornerRadius="8">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="&#x1F4E6;"
                                       FontSize="14"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Backups"
                                       FontSize="14"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Page list -->
                <ListBox Classes="sidebar"
                         ItemsSource="{Binding Pages}"
                         SelectedItem="{Binding SelectedPage}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:PageItem">
                            <TextBlock Text="{Binding Name}"
                                       FontSize="14" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Content area -->
        <Border Grid.Column="1" Padding="32,24">
            <ContentControl Classes="page-host"
                            Content="{Binding CurrentPage}">
                <ContentControl.DataTemplates>
                    <DataTemplate DataType="vm:VariablesViewModel">
                        <views:VariablesView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:StartupViewModel">
                        <views:StartupView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:KeybindingsViewModel">
                        <views:KeybindingsView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:MonitorsViewModel">
                        <views:MonitorsView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:InputViewModel">
                        <views:InputView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:AudioViewModel">
                        <views:AudioView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:PowerViewModel">
                        <views:PowerView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:BackupViewModel">
                        <views:BackupView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:PlaceholderViewModel">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="8">
                            <TextBlock Text="{Binding PageName}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#585b70"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Coming soon"
                                       FontSize="13"
                                       Foreground="#45475a"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </ContentControl.DataTemplates>
            </ContentControl>
        </Border>

    </Grid>

</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Hypricing.Desktop.ViewModels"
        xmlns:views="using:Hypricing.Desktop.Views"
        mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="640"
        x:Class="Hypricing.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Hypricing"
        Width="1000" Height="680">

    <Grid ColumnDefinitions="240,*">

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="#11111b"
                BorderBrush="#1e1e30"
                BorderThickness="0,0,1,0"
                Padding="0,16">
            <DockPanel>
                <!-- App branding -->
                <StackPanel DockPanel.Dock="Top" Margin="20,8,20,20">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border Background="Transparent"
                                CornerRadius="10"
                                Width="36" Height="36"
                                BorderBrush="#89b4fa"
                                BorderThickness="2">
                            <TextBlock Text="⚙"
                                       FontSize="17"
                                       Foreground="#89b4fa"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Hypricing"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#cdd6f4" />
                            <TextBlock Text="Hyprland Settings"
                                       FontSize="10"
                                       Foreground="#45475a" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Separator -->
                <Border DockPanel.Dock="Top" Classes="separator" Margin="20,0,20,8" />

                <!-- Backups at bottom -->
                <StackPanel DockPanel.Dock="Bottom" Margin="10,0">
                    <Border Classes="separator" Margin="6,0,6,6" />
                    <Button Classes="nav-item"
                            Command="{Binding OpenBackupsCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="12,10"
                            CornerRadius="8">
                        <TextBlock Text="Backups" FontSize="13" />
                    </Button>
                </StackPanel>

                <!-- Nav section label -->
                <TextBlock DockPanel.Dock="Top"
                           Text="NAVIGATION"
                           FontSize="10"
                           FontWeight="Bold"
                           Foreground="#45475a"
                           Margin="22,4,0,6" />

                <!-- Page list -->
                <ListBox Classes="sidebar"
                         ItemsSource="{Binding Pages}"
                         SelectedItem="{Binding SelectedPage}"
                         Margin="10,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:PageItem">
                            <TextBlock Text="{Binding Name}" FontSize="13" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Content area -->
        <Border Grid.Column="1" Background="#1e1e2e" Padding="36,28">
            <ContentControl Classes="page-host"
                            Content="{Binding CurrentPage}">
                <ContentControl.DataTemplates>
                    <DataTemplate DataType="vm:VariablesViewModel">
                        <views:VariablesView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:StartupViewModel">
                        <views:StartupView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:KeybindingsViewModel">
                        <views:KeybindingsView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:MonitorsViewModel">
                        <views:MonitorsView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:InputViewModel">
                        <views:InputView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:AudioViewModel">
                        <views:AudioView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:BackupViewModel">
                        <views:BackupView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:PlaceholderViewModel">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="8">
                            <TextBlock Text="{Binding PageName}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#585b70"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Coming soon"
                                       FontSize="13"
                                       Foreground="#45475a"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </ContentControl.DataTemplates>
            </ContentControl>
        </Border>

    </Grid>

</Window>
